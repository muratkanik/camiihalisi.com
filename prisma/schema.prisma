generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          String   @default("admin")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // Can store JSON or text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id             String         @id @default(cuid())
  slug           String         @unique
  titleInternal  String
  seoScore       Int            @default(0)
  blocks         ContentBlock[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ContentBlock {
  id            String        @id @default(cuid())
  pageId        String
  page          Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  componentType String
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  schemaDef     String        @default("{}") // SQLite doesn't natively support JSONB arrays inside Prisma until typed json, we'll store as string
  translations  Translation[]
  createdAt     DateTime      @default(now())
}

model Translation {
  id          String       @id @default(cuid())
  blockId     String
  block       ContentBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  locale      String       // tr, en, ar, fr
  contentData String       @default("{}") // Store JSON structure as string
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([blockId, locale])
}

model AiTask {
  id             String   @id @default(cuid())
  keyword        String
  targetPageSlug String?
  status         String   @default("pending")
  seoScore       Int      @default(0)
  logs           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ContentArchive {
  id           String   @id @default(cuid())
  title        String
  category     String?
  originalText String
  createdAt    DateTime @default(now())
}
